@model DadJokes.Models.Joke

@{
    ViewData["Title"] = "New Riddle";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-lg p-4 bg-light">
                <div class="card-header bg-transparent border-0 text-center">
                    <h2 class="display-6">📜 Post a New Riddle</h2>
                    <p class="text-muted">Challenge the world with your wit.</p>
                </div>
                <hr />
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Question" class="form-control border-primary" placeholder="The Riddle..." />
                            <label asp-for="Question">The Riddle (The Puzzle)</label>
                            <span asp-validation-for="Question" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Answer" class="form-control border-primary" placeholder="The Answer..." />
                            <label asp-for="Answer">The Answer (The Secret)</label>
                            <span asp-validation-for="Answer" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="bi bi-plus-circle"></i> Create Riddle
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm border-0">
                                Cancel and Go Back
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}