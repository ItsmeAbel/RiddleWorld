@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage Profile">
                <span class="badge rounded-pill bg-info text-dark p-2">
                    👤 @User.Identity?.Name.Split('@')[0]
                </span>
            </a>
    </li>
        <li class="nav-item ms-2">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 shadow-sm">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </button>
            </form>
        </li>
}
else
{
        <li class="nav-item">
            <a class="nav-link text-dark fw-bold" asp-area="Identity" asp-page="/Account/Login">
                Login
            </a>
        </li>
        <li class="nav-item d-none d-lg-block">
            <span class="nav-link text-muted">|</span>
        </li>
        <li class="nav-item">
            <a class="nav-link text-primary fw-bold" asp-area="Identity" asp-page="/Account/Register">
                Join the Quest
            </a>
        </li>
}
</ul>
